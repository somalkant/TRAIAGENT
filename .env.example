# Copy this file to .env and fill in your real values
# NEVER commit .env to git

KITE_API_KEY='your_kite_api_key_here'
KITE_API_SECRET='your_kite_api_secret_here'

TOTP_TOKEN_SECRET='your_totp_secret_here'
GROWW_API_TOKEN='your_groww_api_token_here'
GROWW_ACCESS_TOKEN='your_groww_access_token_here'

# News signal (Phase 2.7, monitor-only) — free-tier Google AI Studio key.
# Get one at https://aistudio.google.com/apikey . Optional: without it the
# news classifier falls back to the offline keyword lexicon (source=keyword).
GEMINI_API_KEY='your_gemini_api_key_here'

# AWS S3 (for data sync — NOT needed on EC2 if IAM role is attached)
# On EC2: attach an IAM role with s3:GetObject + s3:PutObject on your bucket
# Locally: run `aws configure` OR set these vars
AWS_ACCESS_KEY_ID='your_aws_access_key_here'
AWS_SECRET_ACCESS_KEY='your_aws_secret_key_here'
AWS_DEFAULT_REGION='ap-south-1'   # Mumbai — closest to NSE
AWS_S3_BUCKET='your-trading-data-bucket-name'
