# Credentials — NEVER commit these
.env
*.pem
checkpoints/access_token.json

# Checkpoints — runtime state, never commit (EC2 pulls from S3; local reads from disk)
checkpoints/*.json
checkpoints/short_wr_opt/*.json
# News signal per-symbol daily cache (runtime)
checkpoints/news_cache/

# Trade-log migration backups (kept locally, not versioned)
data/trade_logs/*.bak

# Data files (too large for git — re-download on AWS via data pipeline)
data/stocks/
data/raw/

# Claude Code project settings (personal/local)
.claude/

# Runtime logs (regenerated automatically)
logs/

# Jupyter checkpoints
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
dist/
build/
.eggs/

# Tests
.pytest_cache/

# OS
.DS_Store
Thumbs.db
